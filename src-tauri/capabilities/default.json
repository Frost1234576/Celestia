{
  "identifier": "default",
  "description": "Default capabilities for Celestia",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:allow-start-dragging",
    "core:window:allow-is-maximized",
    "shell:allow-open"
  ]
}